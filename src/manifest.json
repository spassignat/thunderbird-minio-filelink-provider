{
  "manifest_version": 2,
  "name": "MinIO Filelink",
  "version": "2.0.0",
  "description": "Upload large attachments to MinIO",
  "applications": {
    "gecko": {
      "id": "minio-filelink@exygen.fr",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "storage",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": [
      "account-manager.js",
      "client-config.js",
      "minio-client.js",
      "LoggerProxy.js",
      "background.js"
    ]
  },
  "options_ui": {
    "page": "management.html",
    "open_in_tab": false,
    "browser_style": true
  },
  "cloud_file": {
    "name": "MinIO Filelink",
    "management_url": "management.html",
    "browser_style": true,
    "reuse_uploads": false
  },
  "icons": {
    "64": "icon64.png",
    "32": "icon32.png",
    "16": "icon16.png",
    "48": "icon48.png"
  },
  "default_locale": "en"
}